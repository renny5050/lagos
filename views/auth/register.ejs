<%- include('../partials/header') %>

<main class="container-fluid mb-5 d-flex flex-column justify-content-center" style="min-height: 75vh;">
    <div class="row justify-content-center w-100 mx-0">
        <div class="col-12 col-sm-8 col-md-6 col-lg-4 px-3">
            
            <div class="text-center mb-5 mt-4">
                <span class="tag-label"><i class="bi bi-person-plus-fill me-2"></i>Nuevo Atleta</span>
                <h1 class="display-4 fw-bolder mb-2" style="letter-spacing: -1px; line-height: 1.1;">
                    START YOUR <br> <span style="color: #888;">JOURNEY</span>
                </h1>
                <p class="text-muted">Únete para llevar el control absoluto de tus rutinas.</p>
            </div>

            <div class="bento-card p-4 p-md-5">
                <form action="/register" method="POST">
                    
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Nombre de Usuario</label>
                        <div class="input-group">
                            <span class="input-group-text custom-input border-end-0 bg-light"><i class="bi bi-person"></i></span>
                            <input type="text" name="username" class="form-control custom-input border-start-0 ps-0 bg-light" placeholder="Tu alias en el gym" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text custom-input border-end-0 bg-light"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="email" class="form-control custom-input border-start-0 ps-0 bg-light" placeholder="tu@email.com" required>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Contraseña</label>
                        <div class="input-group">
                            <span class="input-group-text custom-input border-end-0 bg-light"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" class="form-control custom-input border-start-0 ps-0 bg-light" placeholder="Crea una clave segura" required>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-black btn-pill w-100 py-3 mb-4 shadow-sm">
                        CREAR CUENTA <i class="bi bi-check2-circle ms-2"></i>
                    </button>
                    
                </form>

                <div class="text-center mt-2">
                    <p class="small text-muted mb-0">
                        ¿Ya eres miembro? 
                        <a href="/login" class="text-dark fw-bolder text-decoration-none border-bottom border-dark pb-1 ms-1 transition-link">
                            Inicia sesión aquí
                        </a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</main>

<style>
    /* Mantenemos los mismos estilos de input que en el login para consistencia */
    .custom-input {
        background-color: #f7f7f7;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 0.85rem 1rem;
        transition: all 0.2s ease;
    }
    .custom-input:focus, 
    .form-control.custom-input:focus {
        background-color: #fff !important;
        border-color: var(--text-dark) !important;
        box-shadow: 0 0 0 4px rgba(0,0,0,0.05);
        outline: none;
    }
    
    .input-group-text.custom-input {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }
    .form-control.custom-input {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .transition-link:hover {
        opacity: 0.6;
        transition: opacity 0.2s;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>