<%- include('../partials/header') %>

<main class="container-fluid mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="text-center mb-5 mt-3">
                <span class="tag-label"><i class="bi bi-lightning-charge-fill me-2"></i>Nueva Sesión</span>
                <h1 class="display-4 fw-bolder mb-2" style="letter-spacing: -1px; line-height: 1.1;">
                    DESIGN YOUR <br> <span style="color: #888;">WORKOUT</span>
                </h1>
                <p class="text-muted">Registra tu esfuerzo y construye tu disciplina.</p>
            </div>

            <form action="/workout/save" method="POST" id="workout-form">

                <div id="sets-container">
                    <div class="bento-card mb-3 set-item position-relative overflow-hidden">
                        <div class="position-absolute text-muted opacity-25" style="font-size: 6rem; font-weight: 800; top: -20px; right: -10px; z-index: 0; user-select: none;">
                            01
                        </div>
                        
                        <div class="position-relative" style="z-index: 1;">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="mb-0 fw-bolder text-dark tracking-tight">Set 01</h5>
                                <span class="badge bg-dark text-white rounded-pill px-3 py-2 fw-normal">Activa</span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Ejercicio</label>
                                <select name="sets[0][exercise_id]" class="form-select custom-input" required>
                                    <option value="" disabled selected>Selecciona un movimiento...</option>
                                    <% exercises.forEach(ex => { %>
                                        <option value="<%= ex.id %>"><%= ex.name %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="row g-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Repeticiones</label>
                                    <div class="input-group">
                                        <span class="input-group-text custom-input border-end-0"><i class="bi bi-hash"></i></span>
                                        <input type="number" name="sets[0][reps]" class="form-control custom-input border-start-0 ps-0" placeholder="0" required>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Peso (kg)</label>
                                    <div class="input-group">
                                        <span class="input-group-text custom-input border-end-0"><i class="bi bi-box-seam"></i></span>
                                        <input type="number" step="0.1" name="sets[0][weight]" class="form-control custom-input border-start-0 ps-0" placeholder="0.0" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-3 mt-5">
                    <button type="button" id="add-set" class="btn btn-outline-black btn-pill py-3">
                        <i class="bi bi-plus-lg me-2"></i>Añadir siguiente set
                    </button>
                    
                    <button type="submit" class="btn btn-black btn-pill py-3 shadow-sm">
                        GUARDAR ENTRENAMIENTO <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                    
                    <a href="/dashboard" class="btn btn-link text-muted text-decoration-none mt-2">Cancelar y volver</a>
                </div>
            </form>
        </div>
    </div>
</main>

<style>
    /* Estilos específicos para inputs de este formulario para mantener el tono premium */
    .custom-input {
        background-color: #f7f7f7;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        transition: all 0.2s ease;
    }
    .custom-input:focus, 
    .form-select.custom-input:focus, 
    .form-control.custom-input:focus {
        background-color: #fff;
        border-color: var(--text-dark);
        box-shadow: 0 0 0 4px rgba(0,0,0,0.05);
        outline: none;
    }
    .letter-spacing-1 {
        letter-spacing: 1px;
    }
</style>

<script>
    let setCount = 1;
    // Preparamos las opciones de los ejercicios una sola vez
    const exerciseOptions = `<%- exercises.map(ex => `<option value="${ex.id}">${ex.name}</option>`).join('') %>`;

    document.getElementById('add-set').addEventListener('click', () => {
        const container = document.getElementById('sets-container');
        const newSet = document.createElement('div');
        
        // Formatear el número con un 0 a la izquierda (ej: 02, 03)
        const displayNum = String(setCount + 1).padStart(2, '0');
        
        newSet.className = 'bento-card mb-3 set-item position-relative overflow-hidden animate__animated animate__fadeInUp';
        
        newSet.innerHTML = `
            <div class="position-absolute text-muted opacity-25" style="font-size: 6rem; font-weight: 800; top: -20px; right: -10px; z-index: 0; user-select: none;">
                ${displayNum}
            </div>
            
            <div class="position-relative" style="z-index: 1;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 fw-bolder text-dark tracking-tight">Set ${displayNum}</h5>
                    <button type="button" class="btn-close shadow-none" onclick="this.closest('.set-item').remove()" aria-label="Close"></button>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Ejercicio</label>
                    <select name="sets[${setCount}][exercise_id]" class="form-select custom-input" required>
                        <option value="" disabled selected>Selecciona un movimiento...</option>
                        ${exerciseOptions}
                    </select>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Repeticiones</label>
                        <div class="input-group">
                            <span class="input-group-text custom-input border-end-0"><i class="bi bi-hash"></i></span>
                            <input type="number" name="sets[${setCount}][reps]" class="form-control custom-input border-start-0 ps-0" placeholder="0" required>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted text-uppercase letter-spacing-1">Peso (kg)</label>
                        <div class="input-group">
                            <span class="input-group-text custom-input border-end-0"><i class="bi bi-box-seam"></i></span>
                            <input type="number" step="0.1" name="sets[${setCount}][weight]" class="form-control custom-input border-start-0 ps-0" placeholder="0.0" required>
                        </div>
                    </div>
                </div>
            </div>
        `;
        container.appendChild(newSet);
        setCount++;
    });
</script>

</body>
</html>