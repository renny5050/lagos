<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gym Tracker Studio</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #fafafa;
            --text-dark: #0f0f0f;
            --card-light: #ffffff;
            --card-dark: #121212;
            --border-color: #e6e6e6;
        }

        html, body {
            margin: 0; padding: 0; width: 100%; overflow-x: hidden;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            -webkit-font-smoothing: antialiased;
        }

        /* Tipografía Bold y Ajustes */
        h1, h2, h3, h4, h5, h6 {
            letter-spacing: -0.03em;
            font-weight: 800;
        }

        /* Botones estilo "Píldora" (Como en la imagen) */
        .btn-pill {
            border-radius: 50px;
            padding: 12px 28px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-black {
            background-color: var(--text-dark);
            color: #fff;
            border: 1px solid var(--text-dark);
        }
        .btn-black:hover {
            background-color: transparent;
            color: var(--text-dark);
        }
        .btn-outline-black {
            background-color: transparent;
            color: var(--text-dark);
            border: 1px solid var(--border-color);
        }
        .btn-outline-black:hover {
            border-color: var(--text-dark);
        }

        /* Etiquetas flotantes (Como "Welcome to Creatiwise") */
        .tag-label {
            display: inline-block;
            border: 1px solid var(--border-color);
            border-radius: 50px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #555;
            background: #fff;
            margin-bottom: 1.5rem;
        }

        /* Cards estilo Bento */
        .bento-card {
            background: var(--card-light);
            border-radius: 24px;
            border: 1px solid var(--border-color);
            box-shadow: 0 10px 30px rgba(0,0,0,0.02);
            padding: 2rem;
        }
        .bento-dark {
            background: var(--card-dark);
            color: #fff;
            border: none;
        }

        /* Navbar ultra minimalista */
        .custom-nav {
            padding: 1.5rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(10px);
        }
        .nav-links a {
            color: var(--text-dark);
            text-decoration: none;
            margin-right: 2rem;
            font-weight: 500;
            font-size: 0.95rem;
        }
        .nav-links a:hover { opacity: 0.7; }
    </style>
</head>
<body>

<nav class="custom-nav mb-5">
    <div class="fw-bold fs-5 tracking-tight">GymTracker.</div>
    <div class="nav-links d-none d-md-block">
        <a href="/dashboard">Historial</a>
        <a href="/exercises">Catálogo</a>
    </div>
    <div>
        <a href="/workout/new" class="btn btn-black btn-pill btn-sm d-none d-md-inline-block">Let's Train <i class="bi bi-arrow-up-right ms-1"></i></a>
        <a href="/logout" class="btn btn-outline-black btn-pill btn-sm ms-2">Salir</a>
    </div>
</nav>