<%- include('partials/header') %>

<main class="container-fluid mb-5 d-flex flex-column justify-content-center" style="min-height: 75vh;">
    <div class="row justify-content-center w-100 mx-0">
        <div class="col-12 col-sm-8 col-md-6 col-lg-5 px-3 text-center">
            
            <div class="mb-4">
                <span class="badge border border-danger text-danger rounded-pill px-3 py-2 fw-bold" style="background-color: rgba(220, 53, 69, 0.05);">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>ALERTA DEL SISTEMA
                </span>
            </div>

            <h1 class="display-3 fw-bolder mb-3 text-uppercase" style="letter-spacing: -2px; line-height: 1;">
                <%= title || 'ALGO SALIÓ' %> <br> 
                <span style="color: #dc3545;"><%= titleHighlight || 'MAL' %></span>
            </h1>

            <p class="lead text-muted mb-5 px-md-4">
                <%= message || 'Ha ocurrido un error inesperado. Por favor, intenta la acción nuevamente.' %>
            </p>

            <div class="bento-card p-3 d-inline-block shadow-sm">
                <a href="<%= redirectUrl || 'javascript:history.back()' %>" class="btn btn-black btn-pill px-5 py-3 fw-bold">
                    <i class="bi bi-arrow-left me-2"></i> VOLVER ATRÁS
                </a>
            </div>

        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>