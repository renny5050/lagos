<%- include('../partials/header') %>

<main class="container-fluid mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <div class="text-center mb-5 mt-3">
                <span class="tag-label"><i class="bi bi-collection-play me-2"></i>Librería Oficial</span>
                <h1 class="display-4 fw-bolder mb-2" style="letter-spacing: -1px; line-height: 1.1;">
                    MASTER THE <br> <span style="color: #888;">MOVEMENTS</span>
                </h1>
                <p class="text-muted">Consulta la técnica y los grupos musculares del catálogo global.</p>
            </div>

            <div class="bento-card p-0 overflow-hidden mb-4">
                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-0">
                        <thead style="border-bottom: 1px solid var(--border-color);">
                            <tr>
                                <th class="ps-5 py-4 text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 1px; width: 30%;">Movimiento</th>
                                <th class="py-4 text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 1px; width: 30%;">Enfoque Anatómico</th>
                                <th class="pe-5 py-4 text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 1px;">Descripción Técnica</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% exercises.forEach(ex => { 
                                // Lógica para detectar qué músculo iluminar en el SVG
                                const mg = (ex.muscle_group || '').toLowerCase(); 
                                const isPecho = mg.includes('pecho');
                                const isEspalda = mg.includes('espalda');
                                const isHombro = mg.includes('hombro') || mg.includes('deltoide');
                                const isBrazo = mg.includes('brazo') || mg.includes('bíceps') || mg.includes('tríceps');
                                const isPierna = mg.includes('pierna') || mg.includes('cuádriceps') || mg.includes('glúteo') || mg.includes('femoral') || mg.includes('pantorrilla');
                                const isCore = mg.includes('core') || mg.includes('abdomen') || mg.includes('abdominal');
                                
                                const activeColor = '#121212';
                                const inactiveColor = '#e6e6e6';
                            %>
                                <tr style="border-bottom: 1px solid #f5f5f5;">
                                    <td class="ps-5 py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-dark text-white rounded-4 d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; min-width: 48px;">
                                                <i class="bi bi-lightning-fill fs-5"></i>
                                            </div>
                                            <span class="fw-bolder fs-6 text-dark tracking-tight"><%= ex.name %></span>
                                        </div>
                                    </td>
                                    <td class="py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3 map-container">
                                                <svg viewBox="0 0 60 100" width="30" height="50" xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="30" cy="12" r="8" fill="<%= inactiveColor %>" />
                                                    <rect x="12" y="24" width="36" height="10" rx="4" fill="<%= isHombro ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                    <rect x="18" y="36" width="24" height="18" rx="4" fill="<%= (isPecho || isEspalda) ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                    <rect x="10" y="36" width="6" height="25" rx="3" fill="<%= isBrazo ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                    <rect x="44" y="36" width="6" height="25" rx="3" fill="<%= isBrazo ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                    <rect x="20" y="56" width="20" height="12" rx="3" fill="<%= isCore ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                    <rect x="20" y="70" width="8" height="28" rx="4" fill="<%= isPierna ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                    <rect x="32" y="70" width="8" height="28" rx="4" fill="<%= isPierna ? activeColor : inactiveColor %>" style="transition: fill 0.3s ease;"/>
                                                </svg>
                                            </div>
                                            <span class="badge border border-dark text-dark rounded-pill px-3 py-2 fw-medium">
                                                <%= ex.muscle_group %>
                                            </span>
                                        </div>
                                    </td>
                                    <td class="pe-5 py-4">
                                        <p class="text-muted small mb-0 lh-base" style="max-width: 400px;">
                                            <%= ex.description || 'Sin descripción disponible.' %>
                                        </p>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="p-4 rounded-4 border-dashed text-center mt-4">
                <p class="small text-muted mb-0 fw-medium">
                    <i class="bi bi-shield-lock-fill text-dark me-2"></i> 
                    Catálogo de solo lectura. Para añadir nuevas variantes, contacta al administrador del sistema.
                </p>
            </div>

        </div>
    </div>
</main>

<style>
    .border-dashed { 
        border: 2px dashed var(--border-color) !important; 
        background-color: transparent;
    }
    
    .table-borderless tbody tr:hover {
        background-color: #fafafa;
    }

    /* Pequeño efecto hover sobre el vector */
    .table-borderless tbody tr:hover .map-container svg rect[fill="#121212"] {
        opacity: 0.8;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>